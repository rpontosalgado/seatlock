{
  "name": "seatlock",
  "version": "0.1.0",
  "description": "Distributed cinema ticket sales system with concurrency-safe seat reservations",
  "main": "dist/main.js",
  "scripts": {
    "prepare": "husky install",
    "postinstall": "prisma generate",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "migrate:deploy": "prisma migrate deploy",
    "build": "nest build",
    "lint": "eslint \"{src,test}/**/*.ts\" --fix",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "test": "jest --selectProjects unit",
    "test:watch": "jest --watch --selectProjects unit",
    "test:cov": "jest --coverage --selectProjects unit",
    "test:integration": "jest --selectProjects integration",
    "test:e2e": "jest --selectProjects e2e",
    "test:concurrency": "jest --selectProjects concurrency",
    "test:all": "jest"
  },
  "devDependencies": {
    "@commitlint/cli": "^18.2.0",
    "@commitlint/config-conventional": "^18.1.0",
    "@nestjs/cli": "^11.0.21",
    "@nestjs/testing": "^11.1.24",
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.9.1",
    "@types/supertest": "^7.2.0",
    "@typescript-eslint/eslint-plugin": "^8.60.1",
    "@typescript-eslint/parser": "^8.60.1",
    "commitizen": "^4.3.0",
    "cz-conventional-changelog": "^3.3.0",
    "eslint": "^10.4.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.6",
    "husky": "^8.0.3",
    "jest": "^30.4.2",
    "prettier": "^3.8.3",
    "prisma": "^7.8.0",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.11",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3"
  },
  "prisma": {
    "seed": "ts-node prisma/seed.ts"
  },
  "jest": {
    "projects": [
      {
        "displayName": "unit",
        "moduleFileExtensions": ["js", "json", "ts"],
        "rootDir": ".",
        "testRegex": ".*\\.spec\\.ts$",
        "transform": {
          "^.+\\.(t|j)s$": "ts-jest"
        },
        "collectCoverageFrom": ["src/**/*.(t|j)s"],
        "coverageDirectory": "./coverage",
        "testEnvironment": "node",
        "roots": ["<rootDir>/src/"],
        "moduleNameMapper": {
          "^(\\.{1,2}/.*)generated/prisma/client\\.js$": "<rootDir>/src/generated/prisma/client.ts"
        }
      },
      {
        "displayName": "integration",
        "moduleFileExtensions": ["js", "json", "ts"],
        "rootDir": ".",
        "testRegex": ".integration.spec.ts$",
        "transform": {
          "^.+\\.(t|j)s$": "ts-jest"
        },
        "testEnvironment": "node",
        "roots": ["<rootDir>/test/integration/"],
        "moduleNameMapper": {
          "^(\\.{1,2}/.*)generated/prisma/client\\.js$": "<rootDir>/src/generated/prisma/client.ts"
        }
      },
      {
        "displayName": "e2e",
        "moduleFileExtensions": ["js", "json", "ts"],
        "rootDir": ".",
        "testRegex": ".e2e-spec.ts$",
        "transform": {
          "^.+\\.(t|j)s$": "ts-jest"
        },
        "testEnvironment": "node",
        "roots": ["<rootDir>/test/e2e/"],
        "moduleNameMapper": {
          "^(\\.{1,2}/.*)generated/prisma/client\\.js$": "<rootDir>/src/generated/prisma/client.ts"
        }
      },
      {
        "displayName": "concurrency",
        "moduleFileExtensions": ["js", "json", "ts"],
        "rootDir": ".",
        "testRegex": ".concurrency.spec.ts$",
        "transform": {
          "^.+\\.(t|j)s$": "ts-jest"
        },
        "testEnvironment": "node",
        "roots": ["<rootDir>/test/concurrency/"],
        "moduleNameMapper": {
          "^(\\.{1,2}/.*)generated/prisma/client\\.js$": "<rootDir>/src/generated/prisma/client.ts"
        }
      }
    ]
  },
  "config": {
    "commitizen": {
      "path": "./node_modules/cz-conventional-changelog"
    }
  },
  "dependencies": {
    "@nestjs/common": "^11.1.24",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "^11.1.24",
    "@nestjs/platform-express": "^11.1.24",
    "@nestjs/terminus": "^11.1.1",
    "@prisma/client": "^7.8.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "ioredis": "^5.11.1",
    "kafkajs": "^2.2.4",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2"
  }
}
